# Environment Configuration
ENVIRONMENT=development
DEBUG=True

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
GROQ_API_KEY=your_groq_api_key_here
HEYGEN_API_KEY=your_heygen_api_key_here
HEYGEN_AVATAR_ID=your_default_avatar_id

# Frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.vercel.app

# Database
DATABASE_URL=sqlite:///./project.db

# Storage Paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
TEMP_DIR=./temp
FFMPEG_PATH=C:\ffmpeg\ffmpeg-8.1-essentials_build\bin\ffmpeg.exe

# Security
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
